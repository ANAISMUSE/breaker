DASHSCOPE_API_KEY=sk-fa8598854d0d4c62a7a11218b5e1ed60
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
EMBEDDING_MODEL=text-embedding-v3
MULTIMODAL_MODEL=qwen-vl-plus
DEFAULT_PLATFORM=douyin
USE_LLM_SCORING=false

# 采集与合规
ENABLE_REAL_CRAWLER=false
CRAWLER_LEGAL_ACK=false
MEDIACRAWLER_PROJECT_DIR=
MEDIACRAWLER_ENTRY=main.py
MEDIACRAWLER_COMMAND=python {entry} --platform {platform} --keyword "{keyword}" --limit {limit} --output "{output}"
MEDIACRAWLER_OUTPUT_FILE=data/mediacrawler_output.json

# 产品化后端
APP_SECRET=change-me-in-env
# 前端开发（Vite）跨域：逗号分隔来源，默认包含 localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176
STORAGE_BACKEND=mysql
MYSQL_URL=mysql+pymysql://root:jojo777@127.0.0.1:3306/jianping?charset=utf8mb4
# MySQL 示例：
# STORAGE_BACKEND=mysql
# MYSQL_URL=mysql+pymysql://root:password@127.0.0.1:3306/jianping?charset=utf8mb4

# 云手机监测适配层（默认关闭）
ENABLE_CLOUD_MONITOR=false

# （已弃用 Streamlit）原登录页背景变量，保留无妨
LOGIN_PAGE_BACKGROUND="linear-gradient(160deg, #eef2f7 0%, #dde4ef 48%, #e8edf5 100%)"
LOGIN_BG_IMAGE_PATH=
LOGIN_BG_OVERLAY=
