LLM_PROVIDER=dashscope
INFERENCE_MODE=remote

# DashScope/OpenAI-compatible API
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
EMBEDDING_MODEL=qwen3-embedding-4b
MULTIMODAL_MODEL=qwen2.5-omni-7b
TEXT_EMBEDDING_MODEL=qwen3-embedding-4b
MULTIMODAL_EMBEDDING_MODEL=qwen3-embedding-4b
OMNI_MODEL=qwen2.5-omni-7b
REPORT_MODEL=qwen2.5-omni-7b
LLM_REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1.0

# Local OpenAI-compatible endpoint
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_OPENAI_API_KEY=EMPTY
LOCAL_EMBEDDING_MODEL=qwen3-embedding-4b
LOCAL_MULTIMODAL_MODEL=qwen2.5-omni-7b
LORA_ENABLED=false
LORA_BASE_MODEL=qwen2.5-omni-7b
LORA_ADAPTER_PATH=

# Realtime crawler compliance gates
CRAWLER_LEGAL_ACK=false
CRAWLER_ALLOWED_PURPOSES=academic_research,model_evaluation,teaching_demo
